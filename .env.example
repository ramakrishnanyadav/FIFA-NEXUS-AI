
# FIFA Nexus AI — Environment Configuration
# -------------------------------------------------
# DEMO / FRESH-CLONE QUICKSTART
# The values below work immediately after `git clone` + `pip install`.
# No edits required to run the full demo. LLM keys are optional —
# the system falls back to local heuristic SOP templates without them.
# -------------------------------------------------
# Copy this file to .env to persist your own overrides (never committed).

# --- Database (PostgreSQL) ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=fifanexus
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Qdrant Vector DB ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- LLM Provider (set ONE of the following) ---
# Priority: OPENAI_API_KEY > GROQ_API_KEY > FEATHERLESS_API_KEY > heuristic fallback

# Option A: OpenAI — enables GPT-4o-mini + semantic RAG embeddings
# OPENAI_API_KEY=sk-...

# Option B: Groq — fastest inference, Llama-3.3-70B, json_object mode supported
# GROQ_API_KEY=gsk_...
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_MODEL=llama-3.3-70b-versatile

# Option C: Featherless — OpenAI-compatible, no embeddings support
# FEATHERLESS_API_KEY=your_featherless_key_here
# FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
# FEATHERLESS_MODEL=meta-llama/Llama-3.3-70B-Instruct

# --- Security & Environment ---
ENVIRONMENT=development
JWT_SECRET_KEY=nexus_jwt_dev_secret_2026_changeme_in_production
API_KEY=fifanexus_api_key_2026
